{
    "name": "kit-helpers",
    "version": "0.0.0",
    "private": true,
    "description": "Helpers, plugins, and tools for @solana/kit",
    "scripts": {
        "build": "pnpm -r build",
        "test": "pnpm -r test",
        "test:integration": "pnpm -r --if-present test:integration",
        "test:unit": "pnpm -r --if-present test:unit",
        "lint": "oxlint && oxfmt --check",
        "lint:fix": "oxlint --fix && oxfmt",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "dev": "pnpm -r --parallel dev"
    },
    "devDependencies": {
        "@solana-config/oxc": "^0.1.1",
        "oxfmt": "^0.56.0",
        "oxlint": "^1.71.0",
        "oxlint-tsgolint": "^0.23.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
